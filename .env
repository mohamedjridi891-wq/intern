# Database connection string
# Set this to your database connection URL. Example (do NOT commit real secrets):
# DB_URL=postgresql://<user>:<password>@localhost:5432/aidis
DB_URL=

# Local workspace folders
ROOT_FOLDER=C:\Users\jridi\OneDrive\Desktop\ssss\root
REVIEW_FOLDER=C:\Users\jridi\OneDrive\Desktop\ssss\review

# Embedding model settings
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBED_BATCH_SIZE=128
EMBED_MAX_CHARS=2000

# Hugging Face authentication token
# Set your HF token here or in your environment. Do NOT commit real tokens.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=${HF_TOKEN}

# Optional: log filenames
LOGGING_ERRORS=embedding_errors.log
CLEANING_ERRORS=cleaning_errors.log
EXTRACTION_ERRORS=extraction_errors.log

GROQ_API_KEY=

# Phase 9 — Groq rate-limit / retry settings
# Base delay used when provider does not return Retry-After (seconds)
GROQ_RATE_LIMIT_DELAY=0.5

# Maximum number of retry attempts for transient errors / 429 responses
GROQ_MAX_RETRIES=3

# Exponential backoff base multiplier
GROQ_BACKOFF_BASE=2.0

# Optional: percent of files to call the LLM for (0-100). If set, only this
# percent (random sample) will use the LLM; the rest will use templates.
#PH9_LLM_SAMPLE_PERCENT=1
